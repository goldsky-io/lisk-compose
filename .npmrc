# Refuse packages published within the last 7 days to mitigate supply chain attacks
# (e.g. the axios@1.14.1 incident where a malicious version was yanked within hours).
# Requires npm >=11.10.0 — older npm versions silently ignore this setting.
min-release-age=7

# Enforce the engines.npm>=11.10.0 constraint in package.json as a hard failure
# rather than a warning. Without this, npm will warn but proceed on older versions,
# silently skipping min-release-age and defeating the supply chain protection.
engine-strict=true
